# backend/.env.example — backend service config (NO REAL VALUES)
DATABASE_URL=postgresql://role:password@host:5432/dbname
# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
PORT=5000
NODE_ENV=production

# CORS allowlist (comma-separated origins). Defaults applied in server.js if unset.
ALLOWED_ORIGINS=https://your-domain.abacusai.cloud,http://localhost:3000

# ── LUCA AI coach ──────────────────────────────────────────────
# mode: mock | cloud | anthropic | local  (defaults to mock with zero keys)
LUCA_AI_MODE=cloud
LUCA_AI_BASE_URL=https://routellm.abacus.ai/v1
LUCA_AI_MODEL=claude-sonnet-4-6
LUCA_AI_API_KEY=REPLACE_WITH_YOUR_KEY
ANTHROPIC_API_KEY=

# ── Cross-chain wallet RPC endpoints (optional overrides) ──────
ETHEREUM_RPC_URL=
POLYGON_RPC_URL=
SOLANA_RPC_URL=
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
