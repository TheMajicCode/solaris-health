{
  "name": "luca-passport-backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "migrate": "node-pg-migrate up -m migrations",
    "migrate:down": "node-pg-migrate down -m migrations",
    "migrate:create": "node-pg-migrate create -m migrations",
    "migrate:status": "node-pg-migrate up --dry-run -m migrations",
    "seed": "node src/db/seed-demo-data.js",
    "seed:reset": "node src/db/seed-demo-data.js --reset",
    "smoke-test": "node scripts/smoke-test.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "test:watch": "jest --watch",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src tests --ext .js",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src tests --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [],
  "author": "Solaris Health",
  "license": "MIT",
  "description": "LUCA Passport Backend API",
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.17.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^9.0.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "prettier": "^3.9.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageDirectory": "coverage",
    "testTimeout": 30000
  }
}
