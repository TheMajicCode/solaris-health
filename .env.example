# Root .env.example — docker-compose interpolation vars (NO REAL VALUES)
# Public base URL baked into the frontend bundle at build time.
API_URL=https://your-domain.abacusai.cloud
# PostgreSQL password used by the backend + postgres containers.
DB_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD
# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX
NODE_ENV=production
