FROM node:18-slim

WORKDIR /app

# Copy package files
COPY package*.json ./
RUN npm ci

# Copy source
COPY src/ ./src/
COPY public/ ./public/
COPY index.html vite.config.js ./

# Build for production
RUN npm run build

# Serve with static server
RUN npm install -g serve

EXPOSE 3000

CMD ["serve", "-s", "dist", "-l", "3000"]
